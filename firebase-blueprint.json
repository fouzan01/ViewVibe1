{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user points, watch time, and referral stats.",
      "type": "object",
      "properties": {
        "displayName": { "type": "string", "description": "User's display name from Google Auth" },
        "email": { "type": "string", "description": "User's email address" },
        "wallet": { "type": "number", "description": "Current points balance" },
        "earnedFromVideos": { "type": "number", "description": "Points earned from playing the verification game" },
        "earnedFromReferrals": { "type": "number", "description": "Points earned from guest views and sign-up invites" },
        "verifiedWatchTime": { "type": "number", "description": "Total verified watch time in seconds" },
        "personalWatchTime": { "type": "number", "description": "Watch time from personal views" },
        "networkWatchTime": { "type": "number", "description": "Watch time from guest views on shared links" },
        "referrals": { "type": "number", "description": "Total number of successful referrals" },
        "claimedVideos": { "type": "array", "items": { "type": "string" }, "description": "List of video IDs for which rewards have been claimed" },
        "activeMissionId": { "type": "string", "description": "ID of the currently active mission, if any" },
        "extraLives": { "type": "number", "description": "Number of extra lives for the Mission Board" },
        "totalCorrect": { "type": "number", "description": "Total number of correct guesses" }
      },
      "required": ["displayName", "email", "wallet", "earnedFromVideos", "earnedFromReferrals", "verifiedWatchTime", "personalWatchTime", "networkWatchTime", "referrals", "claimedVideos", "extraLives", "totalCorrect"]
    },
    "GuestView": {
      "title": "Guest View Record",
      "description": "Prevents repeat guest rewards from the same device.",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string", "description": "Fingerprint visitor ID" },
        "videoId": { "type": "string", "description": "YouTube video ID" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the view occurred" }
      },
      "required": ["visitorId", "videoId", "createdAt"]
    },
    "Video": {
      "title": "Drop Video",
      "description": "Stores individual video drop details.",
      "type": "object",
      "properties": {
        "youtubeVideoId": { "type": "string", "description": "The ID of the YouTube video" },
        "correctColor": { "type": "string", "description": "The correct color for verification" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the video was published" },
        "isActive": { "type": "boolean", "description": "Whether the video is currently active" }
      },
      "required": ["youtubeVideoId", "correctColor", "createdAt", "isActive"]
    },
    "Redemption": {
      "title": "Reward Redemption",
      "description": "Stores reward redemption requests and their status.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user who redeemed the reward" },
        "userEmail": { "type": "string", "description": "Email of the user" },
        "displayName": { "type": "string", "description": "Display name of the user" },
        "rewardName": { "type": "string", "description": "Name of the redeemed reward" },
        "cost": { "type": "number", "description": "Points cost of the reward" },
        "status": { "type": "string", "enum": ["Pending", "Completed"], "description": "Current status of fulfillment" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the redemption occurred" },
        "completedAt": { "type": "string", "format": "date-time", "description": "When the redemption was approved" }
      },
      "required": ["userId", "userEmail", "displayName", "rewardName", "cost", "status", "createdAt"]
    },
    "Reward": {
      "title": "Store Reward",
      "description": "Stores dynamic reward items for the store.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Name of the reward" },
        "cost": { "type": "number", "description": "Points cost" },
        "isActive": { "type": "boolean", "description": "Whether the reward is visible in the store" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the reward was created" }
      },
      "required": ["title", "cost", "isActive", "createdAt"]
    },
    "Transaction": {
      "title": "User Transaction",
      "description": "Stores point earnings and spendings.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user" },
        "type": { "type": "string", "enum": ["earn", "spend"], "description": "Type of transaction" },
        "amount": { "type": "number", "description": "Amount of points" },
        "note": { "type": "string", "description": "Description of the transaction" },
        "date": { "type": "string", "description": "ISO date string (YYYY-MM-DD)" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Firestore server timestamp" }
      },
      "required": ["userId", "type", "amount", "note", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document indexed by Firebase Auth UID."
    },
    "/videos/{videoId}": {
      "schema": "Video",
      "description": "Individual video drop documents."
    },
    "/redemptions/{redemptionId}": {
      "schema": "Redemption",
      "description": "Collection of reward redemption requests."
    },
    "/rewards/{rewardId}": {
      "schema": "Reward",
      "description": "Dynamic store reward items."
    },
    "/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of user point transactions."
    },
    "/guest_views/{guestViewId}": {
      "schema": "GuestView",
      "description": "Collection of guest view records to prevent abuse."
    }
  }
}
